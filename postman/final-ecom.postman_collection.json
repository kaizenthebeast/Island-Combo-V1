    {
      "name": "Cash Vouchers (staff scanner)",
      "description": "Endpoints for the QR-scanner app. Log in as a STAFF/ADMIN user first (a customer token gets 403). The QR encodes the voucher `code` — send that as `code`.",
      "item": [
        {
          "name": "Validate Voucher (scan)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"CV-2026-549A95AED4\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/cash-vouchers/validate",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "cash-vouchers", "validate" ]
            },
            "description": "Read-only check of a scanned QR `code` — never mutates.\n\n200 => { valid, status, reason, voucher? }\n  valid: true only when status === 'ACTIVE'\n  reason: OK | NOT_FOUND | ALREADY_REDEEMED | EXPIRED | CANCELLED\n\nRequires a staff/admin Bearer token: 401 (no/invalid token), 403 (non-staff)."
          }
        },
        {
          "name": "Redeem Voucher (release cash)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"CV-2026-549A95AED4\",\n  \"redeemerName\": \"Person collecting the cash\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/cash-vouchers/redeem",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "cash-vouchers", "redeem" ]
            },
            "description": "Atomically flips an ACTIVE voucher to REDEEMED.\n\n200 => { data: <redeemed voucher>, message }\n400 (missing fields) - 401 (no token) - 403 (non-staff)\n404 (code not found) - 409 (already redeemed / not ACTIVE)\n\nSingle-redeem-safe: a second concurrent redeem gets 409."
          }
        }
      ]
    }
  ]
}
